rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /projects/{slug} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /news/{slug} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
